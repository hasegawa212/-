# =====================================
# Ultimate AI Agent — 環境変数テンプレ
# =====================================
# .env として複製し、値を埋めて使う。
# 本番（公開）デプロイ時の必須項目に★を付記。

# ---- 認証（本番では必須）----
# ★ ADMIN_USERNAME / ADMIN_PASSWORD を必ず設定すること。
# 未設定の場合、開発モードでは admin/admin が一時的に許可されるが、
# NODE_ENV=production では完全にロックされる。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- OpenAI（チャット・画像生成等で使用）----
# 公開モードでは OpenAI 使用ページは無効化されるため省略可。
# 完全機能で使う場合のみ設定。
OPENAI_API_KEY=sk-your-api-key-here

# ---- サーバー基本設定 ----
PORT=3000
DATABASE_URL=./data/app.db
NODE_ENV=development

# ---- 公開モード（社外公開時に true）----
# true にすると以下が有効化される:
#   - サーバ: OpenAI を使う全エンドポイントを 403 で塞ぐ
#   - クライアント: 仕入れシミュ 2 ページ + 案件履歴 + 設定 のみ表示
#   - ルートアクセスは /loan-simulator にリダイレクト
# クライアント側は Vite ビルド時に埋め込まれるため
# VITE_PUBLIC_MODE 名で同値を指定すること（両方必要）。
PUBLIC_MODE=false
VITE_PUBLIC_MODE=false
