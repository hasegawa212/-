{
  "name": "Telegram Call Log → Telephone Sheet Update",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "id": "2a0e3a01-1111-4b01-9001-000000000001",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "telegram-call-log",
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Expected formats:\n//   \"<No.> <結果>\"             e.g. \"3 アポ獲得\"\n//   \"/log <No.> <結果>\"\n//   \"<No.>:<結果>\"\n// 結果 keywords (case-insensitive):\n//   アポ獲得 / アポ / 不在 / 留守 / 拒否 / 再架電 / 番号違い / その他\n\nconst raw = ($json.message?.text || '').trim();\nconst stripped = raw.replace(/^\\/log\\s+/i, '').replace(/[：:]/g, ' ');\nconst match = stripped.match(/^\\s*(\\d+)\\s+(.+)$/s);\n\nif (!match) {\n  return [{\n    json: {\n      ok: false,\n      reason: 'parse_error',\n      raw,\n      hint: '使い方: \"<No.> <結果>\" 例) 3 アポ獲得',\n      reply_chat_id: $json.message.chat.id,\n      reply_message_id: $json.message.message_id,\n    },\n  }];\n}\n\nconst no = Number(match[1]);\nconst result = match[2].trim();\n\n// Map result keyword to next 架電ステータス\nconst statusMap = [\n  { re: /アポ獲得|獲得|成約/i, status: 'アポ獲得' },\n  { re: /アポ($|[^獲])/i,       status: 'アポ予定' },\n  { re: /不在|留守/i,           status: '次回架電予定' },\n  { re: /拒否|断り|NG/i,         status: '対応不可' },\n  { re: /再架電|再電|折り返し/i, status: '次回架電予定' },\n  { re: /番号違い|誤番/i,        status: '番号誤り' },\n];\nconst nextStatus = (statusMap.find(s => s.re.test(result)) || { status: '架電済み' }).status;\nconst isAppointment = /アポ獲得|獲得|成約/i.test(result);\n\nreturn [{\n  json: {\n    ok: true,\n    no,\n    result,\n    next_status: nextStatus,\n    is_appointment: isAppointment,\n    today: new Date().toISOString().slice(0, 10),\n    operator: $json.message.from.username || ($json.message.from.first_name || '') + ' ' + ($json.message.from.last_name || ''),\n    reply_chat_id: $json.message.chat.id,\n    reply_message_id: $json.message.message_id,\n  },\n}];"
      },
      "id": "2a0e3a01-2222-4b02-9002-000000000002",
      "name": "Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "ok",
              "leftValue": "={{ $json.ok }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "2a0e3a01-3333-4b03-9003-000000000003",
      "name": "Parse OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 300]
    },
    {
      "parameters": {
        "operation": "lookup",
        "documentId": {
          "__rl": true,
          "value": "REPLACE_WITH_GOOGLE_SHEET_ID",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "テレアポ管理シート",
          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "No.",
              "lookupValue": "={{ $json.no }}"
            }
          ]
        },
        "options": { "returnAllMatches": false }
      },
      "id": "2a0e3a01-4444-4b04-9004-000000000004",
      "name": "Lookup Row by No.",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [880, 200],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const row = $json;\nconst input = $('Parse Command').item.json;\n\nlet slot = 0;\nfor (let i = 1; i <= 3; i++) {\n  const v = row[`架電日${i}`];\n  if (v === undefined || v === null || String(v).trim() === '') {\n    slot = i;\n    break;\n  }\n}\n\nif (slot === 0) {\n  return [{\n    json: {\n      ok: false,\n      reason: 'no_slot',\n      no: input.no,\n      message: `No.${input.no} は既に3回架電済みです。手動で更新してください。`,\n      reply_chat_id: input.reply_chat_id,\n      reply_message_id: input.reply_message_id,\n    },\n  }];\n}\n\nreturn [{\n  json: {\n    ok: true,\n    slot,\n    row_no: row['No.'],\n    name: row['お名前'],\n    phone: row['電話番号'],\n    next_status: input.next_status,\n    result: input.result,\n    today: input.today,\n    operator: input.operator,\n    is_appointment: input.is_appointment,\n    reply_chat_id: input.reply_chat_id,\n    reply_message_id: input.reply_message_id,\n  },\n}];"
      },
      "id": "2a0e3a01-5555-4b05-9005-000000000005",
