    {
      "parameters": {
        "jsCode": "const files = $input.first().json.files || [];\n// フォルダ名から日付(YYYY.M.D)を抽出し、最新（最大）を選ぶ。同点は createdTime が新しい方。\nfunction dateKey(name) {\n  const m = (name || '').match(/(\\d{4})\\.(\\d{1,2})\\.(\\d{1,2})/);\n  if (!m) return 0;\n  return parseInt(m[1], 10) * 10000 + parseInt(m[2], 10) * 100 + parseInt(m[3], 10);\n}\nlet best = null;\nfor (const f of files) {\n  const k = dateKey(f.name);\n  if (!best || k > best.key || (k === best.key && (f.createdTime || '') > (best.createdTime || ''))) {\n    best = { id: f.id, name: f.name, key: k, createdTime: f.createdTime };\n  }\n}\nconst src = $('Get Export URL').item.json;\nif (!best) {\n  return [{ json: { error: true, reason: 'no-seikyubun-folder', channel: src.channel, message_ts: src.message_ts } }];\n}\nreturn [{ json: { error: false, latestFolderId: best.id, latestFolderName: best.name, download_url: src.download_url, filename: src.filename, channel: src.channel, message_ts: src.message_ts, invoice_name: src.invoice_name } }];"
      },
