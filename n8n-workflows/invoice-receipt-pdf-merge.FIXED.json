        "jsCode": "const data = $input.first().json.data || {};\nconst tasks = data.tasks || [];\nconst exp = tasks.find(t => t.operation === 'export/url' && t.status === 'finished');\nif (!exp || !exp.result || !exp.result.files || !exp.result.files.length) {\n  return [{ json: { error: true, reason: 'no-export', status: data.status } }];\n}\nconst src = $('Build CloudConvert Job').item.json;\nreturn [{ json: { error: false, download_url: exp.result.files[0].url, filename: src.filename, channel: src.channel, message_ts: src.message_ts, invoice_name: src.invoice_name } }];"
