{
  "name": "Slack Reaction → Invoice + Receipt PDF Merge → Drive (請求分) [FIXED]",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "slack-invoice-merge",
        "responseMode": "responseNode",
        "options": {
          "rawBody": false
        }
      },
      "id": "merge-01-webhook",
      "name": "Slack Events Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        400
      ],
      "webhookId": "slack-invoice-merge"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst headers = input.headers || {};\n// Slack のリトライ（200応答が遅い時に最大3回再送）は無視して重複格納を防ぐ\nif (headers['x-slack-retry-num'] || headers['X-Slack-Retry-Num']) {\n  return [{ json: { skip: true, reason: 'slack-retry' } }];\n}\nconst body = input.body ?? input;\n// Slack Events API の URL 検証ハンドシェイク\nif (body.type === 'url_verification') {\n  return [{ json: { isChallenge: true, challenge: body.challenge, skip: true } }];\n}\nconst TARGET = 'moneybag'; // トリガー絵文字（:なし）。標準絵文字 💰 のため登録不要。変更する場合はここを書き換え\nconst ev = body.event || {};\nif (ev.type !== 'reaction_added' || ev.reaction !== TARGET) {\n  return [{ json: { skip: true, reason: 'not-target-reaction' } }];\n}\nif (!ev.item || ev.item.type !== 'message') {\n  return [{ json: { skip: true, reason: 'not-message-item' } }];\n}\nreturn [{ json: { skip: false, isChallenge: false, channel: ev.item.channel, message_ts: ev.item.ts, reactor: ev.user } }];"
      },
      "id": "merge-02-parse",
      "name": "Parse Slack Event",
      "type": "n8n-nodes-base.code",
