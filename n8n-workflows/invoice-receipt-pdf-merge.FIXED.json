        "jsCode": "const sub = ($input.first().json.files) || [];\nconst prev = $('Pick Latest 請求分').item.json;\n// 「4.支払いの請求書全て」サブフォルダがあればそこへ、無ければ月フォルダ直下へ\nconst hasSub = sub.length > 0 && sub[0].id;\nconst folderId = hasSub ? sub[0].id : prev.latestFolderId;\nconst folderPath = hasSub ? (prev.latestFolderName + ' / ' + sub[0].name) : prev.latestFolderName;\nreturn [{ json: { folderId, folderPath, download_url: prev.download_url, filename: prev.filename, channel: prev.channel, message_ts: prev.message_ts, invoice_name: prev.invoice_name } }];"
