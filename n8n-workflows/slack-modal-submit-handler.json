            { "outputKey": "apo", "conditions": { "options": { "caseSensitive": true }, "conditions": [{ "leftValue": "={{ $json.callback_id }}", "rightValue": "apo_action", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
            { "outputKey": "feedback", "conditions": { "options": { "caseSensitive": true }, "conditions": [{ "leftValue": "={{ $json.callback_id }}", "rightValue": "customer_feedback", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } }
          ]
        },
        "options": {}
      },
